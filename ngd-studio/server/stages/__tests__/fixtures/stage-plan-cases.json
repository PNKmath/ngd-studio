      "totalQuestions": [1, 2, 3],
      "perQuestion": [
        { "questionNumber": 1, "stages": ["extractor", "solver", "verifier"] },
        { "questionNumber": 2, "stages": ["extractor", "solver", "verifier"] },
        { "questionNumber": 3, "stages": ["extractor", "solver", "verifier"] }
      ]
    }
  },

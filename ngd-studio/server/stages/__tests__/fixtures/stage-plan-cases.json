        { "questionNumber": 1, "stages": ["solver", "verifier"] },
        { "questionNumber": 2, "stages": ["solver", "verifier"] },
        { "questionNumber": 3, "stages": ["extractor", "solver", "verifier"] }
      ]
    }
  },
  {
    "id": "resume-from-verifier-override",

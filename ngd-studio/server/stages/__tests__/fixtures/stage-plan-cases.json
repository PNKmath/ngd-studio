    "states": { "1": "extracted", "2": "none" },
    "allQuestions": [1, 2],
    "expected": {
      "totalQuestions": [1, 2],
      "perQuestion": [
        { "questionNumber": 1, "stages": ["solver", "verifier"] },
        { "questionNumber": 2, "stages": ["extractor", "solver", "verifier"] }
      ]
    }
  },
  {
    "id": "partial-solved",

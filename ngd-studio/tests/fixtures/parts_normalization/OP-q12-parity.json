{
  "id": "OP-q12-parity",
  "rule_ids": [
    "R-10"
  ],
  "description": "운영 데이터 q12 — Python normalize_parts 출력 스냅샷 (cross-language parity)",
  "input": {
    "parts": [
      {
        "t": "f(x) = f(x - 4) + 8에서 x를 x + 4로 바꾸면"
      },
      {
        "br": true
      },
      {
        "eq": "f(x + 4) = f(x) + 8"
      },
      {
        "br": true
      },
      {
        "t": "f(x)가 실수 전체에서 연속이므로 "
      },
      {
        "eq": "x = 2"
      },
      {
        "t": "에서 연속이어야 한다."
      },
      {
        "br": true
      },
      {
        "t": "f(x + 4) = f(x) + 8에 "
      },
      {
        "eq": "x = - 2"
      },
      {
        "t": "를 대입하면"
      },
      {
        "br": true
      },
      {
        "eq": "f(2) = f(- 2) + 8"
      },
      {
        "br": true
      },
      {
        "eq": "f(- 2) = - {1 over 2} times 4 + a times (- 2) = - 2 - 2a"
      },
      {
        "br": true
      },
      {
        "t": "이므로 "
      },
      {
        "eq": "f(2) = (- 2 - 2a) + 8 = 6 - 2a"
      },
      {
        "br": true
      },
      {
        "t": "좌극한 "
      },
      {
        "eq": "lim_{x -> 2^-} f(x) = - {1 over 2} times 4 + 2a = - 2 + 2a"
      },
      {
        "br": true
      },
      {
        "t": "연속 조건에서"
      },
      {
        "br": true
      },
      {
        "eq": "- 2 + 2a = 6 - 2a"
      },
      {
        "br": true
      },
      {
        "eq": "4a = 8"
      },
      {
        "br": true
      },
      {
        "eq": "a = 2"
      },
      {
        "br": true
      },
      {
        "t": "따라서 "
      },
      {
        "eq": "- 2 leq x < 2"
      },
      {
        "t": "일 때 "
      },
      {
        "eq": "f(x) = - {1 over 2} x^2 + 2x"
      },
      {
        "br": true
      },
      {
        "t": "f(x + 4) = f(x) + 8에서"
      },
      {
        "br": true
      },
      {
        "t": "x ∈ [−4, −2)이면 x + 4 ∈ [0, 2)이므로"
      },
      {
        "br": true
      },
      {
        "eq": "f(x) = f(x + 4) - 8"
      },
      {
        "eq": "= - {1 over 2} (x + 4)^2 + 2(x + 4) - 8"
      },
      {
        "eq": "= - {1 over 2} x^2 - 2x - 8"
      },
      {
        "br": true
      },
      {
        "t": "x ∈ [2, 6)이면 x − 4 ∈ [−2, 2)이므로"
      },
      {
        "br": true
      },
      {
        "eq": "f(x) = f(x - 4) + 8"
      },
      {
        "eq": "= - {1 over 2} (x - 4)^2 + 2(x - 4) + 8"
      },
      {
        "eq": "= - {1 over 2} x^2 + 6x - 8"
      },
      {
        "br": true
      },
      {
        "t": "[−4, 0]에서 f(x) ≤ 0이므로"
      },
      {
        "br": true
      },
      {
        "eq": "rmA = - int_{- 4}^{- 2} f(x) dx - int_{- 2}^0 f(x) dx"
      },
      {
        "br": true
      },
      {
        "eq": "- int_{- 4}^{- 2} f(x) dx = int_{- 4}^{- 2} LEFT ( {1 over 2} x^2 + 2x + 8 RIGHT ) dx"
      },
      {
        "eq": "= LEFT [ {x^3 over 6} + x^2 + 8x RIGHT ]_{- 4}^{- 2}"
      },
      {
        "eq": "= LEFT ( - {4 over 3} + 4 - 16 RIGHT ) - LEFT ( - {32 over 3} + 16 - 32 RIGHT )"
      },
      {
        "eq": "= LEFT ( - {4 over 3} - 12 RIGHT ) - LEFT ( - {32 over 3} - 16 RIGHT )"
      },
      {
        "eq": "= - {4 over 3} - 12 + {32 over 3} + 16"
      },
      {
        "eq": "= {28 over 3} + 4"
      },
      {
        "eq": "= {40 over 3}"
      },
      {
        "br": true
      },
      {
        "eq": "- int_{- 2}^0 f(x) dx = int_{- 2}^0 LEFT ( {1 over 2} x^2 - 2x RIGHT ) dx"
      },
      {
        "eq": "= LEFT [ {x^3 over 6} - x^2 RIGHT ]_{- 2}^0"
      },
      {
        "eq": "= 0 - LEFT ( - {4 over 3} - 4 RIGHT )"
      },
      {
        "eq": "= {4 over 3} + 4"
      },
      {
        "eq": "= {16 over 3}"
      },
      {
        "br": true
      },
      {
        "eq": "rmA = {40 over 3} + {16 over 3}"
      },
      {
        "eq": "= {56 over 3}"
      },
      {
        "br": true
      },
      {
        "t": "[0, 6]에서 f(x) ≥ 0이므로"
      },
      {
        "br": true
      },
      {
        "eq": "rmB = int_0^2 f(x) dx + int_2^6 f(x) dx"
      },
      {
        "br": true
      },
      {
        "eq": "int_0^2 f(x) dx = int_0^2 LEFT ( - {1 over 2} x^2 + 2x RIGHT ) dx"
      },
      {
        "eq": "= LEFT [ - {x^3 over 6} + x^2 RIGHT ]_0^2"
      },
      {
        "eq": "= - {4 over 3} + 4"
      },
      {
        "eq": "= {8 over 3}"
      },
      {
        "br": true
      },
      {
        "eq": "int_2^6 f(x) dx = int_2^6 LEFT ( - {1 over 2} x^2 + 6x - 8 RIGHT ) dx"
      },
      {
        "eq": "= LEFT [ - {x^3 over 6} + 3x^2 - 8x RIGHT ]_2^6"
      },
      {
        "eq": "= (- 36 + 108 - 48) - LEFT ( - {4 over 3} + 12 - 16 RIGHT )"
      },
      {
        "eq": "= 24 - LEFT ( - {16 over 3} RIGHT )"
      },
      {
        "eq": "= 24 + {16 over 3}"
      },
      {
        "eq": "= {88 over 3}"
      },
      {
        "br": true
      },
      {
        "eq": "rmB = {8 over 3} + {88 over 3}"
      },
      {
        "eq": "= {96 over 3}"
      },
      {
        "eq": "= 32"
      },
      {
        "br": true
      },
      {
        "t": "따라서"
      },
      {
        "br": true
      },
      {
        "eq": "rmA + rmB = {56 over 3} + 32"
      },
      {
        "eq": "= {56 over 3} + {96 over 3}"
      },
      {
        "eq": "= {152 over 3}"
      }
    ]
  },
